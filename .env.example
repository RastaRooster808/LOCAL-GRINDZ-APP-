# ── Client-side (Vite) — safe to expose ─────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Edge Functions (Supabase secrets, never commit real values) ──
# Copy from: Supabase Dashboard → Project Settings → Connect
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=your-secret-key-here
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# ── Email (optional — for order-notify Edge Function) ───────────
RESEND_API_KEY=re_...
SITE_URL=https://your-github-username.github.io/LOCAL-GRINDZ-APP-
